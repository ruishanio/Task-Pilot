<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
	"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruishanio.taskpilot.admin.mapper.UserMapper">

	<resultMap id="User" type="com.ruishanio.taskpilot.admin.model.User" >
		<result column="id" property="id" />
		<result column="username" property="username" />
	    <result column="password" property="password" />
		<result column="token" property="token" />
	    <result column="role" property="role" />
	    <result column="permission" property="permission" />
	</resultMap>

	<sql id="Base_Column_List">
		t.id,
		t.username,
		t.password,
		t.token,
		t.role,
		t.permission
	</sql>

	<select id="pageList" parameterType="java.util.HashMap" resultMap="User">
		SELECT <include refid="Base_Column_List" />
		FROM "user" AS t
		<trim prefix="WHERE" prefixOverrides="AND | OR" >
			<if test="username != null and username != ''">
				AND t.username like '%' || #{username} || '%'
			</if>
			<if test="role gt -1">
				AND t.role = #{role}
			</if>
		</trim>
		ORDER BY username ASC
		LIMIT #{pagesize} OFFSET #{offset}
	</select>

	<select id="pageListCount" parameterType="java.util.HashMap" resultType="int">
		SELECT count(1)
		FROM "user" AS t
		<trim prefix="WHERE" prefixOverrides="AND | OR" >
			<if test="username != null and username != ''">
				AND t.username like '%' || #{username} || '%'
			</if>
			<if test="role gt -1">
				AND t.role = #{role}
			</if>
		</trim>
	</select>

	<select id="loadByUserName" parameterType="java.util.HashMap" resultMap="User">
		SELECT <include refid="Base_Column_List" />
		FROM "user" AS t
		WHERE t.username = #{username}
	</select>

	<select id="loadById" parameterType="java.util.HashMap" resultMap="User">
		SELECT <include refid="Base_Column_List" />
		FROM "user" AS t
		WHERE t.id = #{id}
	</select>

	<insert id="save" parameterType="com.ruishanio.taskpilot.admin.model.User" useGeneratedKeys="true" keyProperty="id" >
		INSERT INTO "user" (
			username,
			password,
			role,
			permission
		) VALUES (
			#{username},
			#{password},
			#{role},
			#{permission}
		);
	</insert>

	<update id="update" parameterType="com.ruishanio.taskpilot.admin.model.User" >
		UPDATE "user"
		SET
			<if test="password != null and password != ''">
				password = #{password},
			</if>
			role = #{role},
			permission = #{permission}
		WHERE id = #{id}
	</update>

	<delete id="delete" parameterType="java.util.HashMap">
		DELETE
		FROM "user"
		WHERE id = #{id}
	</delete>

	<update id="updateToken" parameterType="java.util.HashMap" >
		UPDATE "user"
		SET token = #{token}
		WHERE id = #{id}
	</update>

	<update id="updatePassword" parameterType="java.util.HashMap" >
		UPDATE "user"
		SET password = #{password}
		WHERE id = #{id}
	</update>

</mapper>
